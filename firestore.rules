rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /quiz/{quizId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Flashcards preset (read-only)
    match /flashcards/{fcId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Review progress per-user (flat)
      match /flashcard_states/{stateId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    match /schedules/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.u_id;
      allow create: if request.auth != null && request.resource.data.u_id == request.auth.uid;
    }

    match /notes/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.u_id;
      allow create: if request.auth != null && request.resource.data.u_id == request.auth.uid;
    }

    match /tasks/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.u_id;
      allow create: if request.auth != null && request.resource.data.u_id == request.auth.uid;
    }

    match /user_progress/{docId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.u_id;
      allow create: if request.auth != null && request.resource.data.u_id == request.auth.uid;
    }

    match /focus_sessions/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.u_id;
      allow create: if request.auth != null && request.resource.data.u_id == request.auth.uid;
    }
  }
}
